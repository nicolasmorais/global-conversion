# Database
DATABASE_URL="postgresql://user:password@host:port/database"

# Stripe (PRODUCAO - use chaves sk_live_ e pk_live_)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# Cloudflare R2 (backup de pedidos)
S3_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="onenotion"
S3_REGION="auto"

# Meta Pixel / CAPI
NEXT_PUBLIC_META_PIXEL_ID=""
META_ACCESS_TOKEN=""

# Taboola Pixel
NEXT_PUBLIC_TABOOLA_PIXEL_ID=""

# Resend (emails - use dominio verificado)
RESEND_API_KEY="re_..."
RESEND_FROM="noreply@seudominio.com"

# Admin (USE SENHA FORTE - min 12 caracteres)
ADMIN_PASSWORD="sua_senha_forte_aqui"
JWT_SECRET="gere_um_segredo_longo_e_aleatorio_aqui"

# App (URL de producao)
NEXT_PUBLIC_APP_URL="https://seudominio.com"
